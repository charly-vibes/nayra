{"actor":"charly vibes","comment":null,"created_at":"2026-03-05T20:01:51Z","event_type":"status_changed","id":168,"issue_id":"nayra-d7g","new_value":"{\"status\":\"in_progress\"}","old_value":"{\"id\":\"nayra-d7g\",\"title\":\"Add Graceful Failure section to browser support doc\",\"description\":\"The documentation lists requirements but doesn't describe the fallback behavior for unsupported browsers. Recommendation: Add a section to docs/browser-support.md describing the error UI shown when required APIs are missing. CRITICAL: Follow TDD and Tidy First.\",\"status\":\"open\",\"priority\":3,\"issue_type\":\"task\",\"owner\":\"charly.vibes@proton.me\",\"created_at\":\"2026-03-05T22:55:54Z\",\"created_by\":\"charly vibes\",\"updated_at\":\"2026-03-05T22:55:54Z\"}"}
