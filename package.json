{
  "name": "nayra",
  "version": "0.1.0",
  "description": "High-performance vanilla JS timeline visualization for deep time",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && esbuild src/main.js --bundle --minify --format=esm --sourcemap --outfile=dist/main.js && cp index.html dist/ && sed -i 's/src=\"src\\/main.js\"/src=\"main.js\"/g' dist/index.html && cp -r examples dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.57.0",
    "esbuild": "^0.27.3",
    "jsdom": "^27.4.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "timeline",
    "visualization",
    "canvas",
    "bigint",
    "deep-time"
  ],
  "license": "MIT",
  "browserslist": [
    "Chrome >= 90",
    "Edge >= 90",
    "Firefox >= 90",
    "Safari >= 14"
  ]
}
